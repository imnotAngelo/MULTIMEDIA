{
  "name": "interactive-learning-backend",
  "version": "1.0.0",
  "description": "Backend API for Interactive Learning System",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/server.ts",
    "setup": "node --import tsx setup-db.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm --prefix lab-publisher start\"",
    "build": "tsc",
    "start": "tsx src/server.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "groq-sdk": "^0.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "tsx": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3"
  }
}
