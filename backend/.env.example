# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# Server Configuration
PORT=3001
# Listen address (0.0.0.0 = LAN + Render/Railway; use 127.0.0.1 to bind locally only)
HOST=0.0.0.0
NODE_ENV=development

# Frontend origins for CORS (comma-separated). Use this for deployed + local Vite together:
# FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app
# Or set ALLOWED_ORIGINS instead (same format); it overrides FRONTEND_URL if both are set.
FRONTEND_URL=http://localhost:5173
