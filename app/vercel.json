{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "https://multimedia-2-x7ol.onrender.com/api"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html",
      "conditions": [
        {
          "key": "pathname",
          "operator": "notStartsWith",
          "value": "/api"
        },
        {
          "key": "pathname",
          "operator": "notStartsWith",
          "value": "/assets"
        },
        {
          "key": "pathname",
          "operator": "notStartsWith",
          "value": "/favicon"
        }
      ]
    }
  ]
}
